<?xml version="1.0" encoding="utf-8"?>
<!--
   Cloud-backup + device-transfer rules (API 31+).
   Only files/upload/ is backed up. Credentials and sensitive paths
   (databases, datastore, known_hosts) are excluded by default via include-only mode.
-->
<data-extraction-rules>
  <cloud-backup>
    <include domain="file" path="upload/" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
  </cloud-backup>
  <device-transfer>
    <include domain="file" path="upload/" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
  </device-transfer>
</data-extraction-rules>
